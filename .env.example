# Copy this file to .env and fill in your values
# Never commit the .env file to Git

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
# Required for AI-generated quizzes and "Practice Weak Areas"
OPENAI_API_KEY=sk-...your-key-here...

# Secret used to encrypt API keys stored in the database
# Use any random string — generate one with: openssl rand -hex 32
ENCRYPTION_SECRET=change-me-to-a-random-secret-string
