# Copy this file to .env and fill in your values
# Never commit the .env file to Git

# OpenAI API key
OPENAI_API_KEY=sk-...your-key-here...

# Secrets (generate with: openssl rand -hex 32)
ENCRYPTION_SECRET=change-me-to-a-random-secret-string
APP_SECRET_KEY=change-me-to-a-random-jwt-secret

# PostgreSQL credentials
POSTGRES_USER=istqb
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=istqb_quiz

# Initial admin account (used only on first startup to seed the DB)
# After first run, credentials are stored encrypted in the database
ADMIN_USERNAME=your@email.com
ADMIN_PASSWORD=your-password
