# Copy this file to .env and fill in your values
# Never commit the .env file to Git

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...your-key-here...

# Secret used to encrypt API keys stored in the database
# Generate: openssl rand -hex 32
ENCRYPTION_SECRET=change-me-to-a-random-secret-string

# PostgreSQL credentials
POSTGRES_USER=istqb
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=istqb_quiz

# Auth — single admin account
ADMIN_USERNAME=admin
# Generate password hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=$2b$12$...bcrypt-hash-here...
# JWT signing secret — generate: openssl rand -hex 32
APP_SECRET_KEY=change-me-to-a-random-jwt-secret
